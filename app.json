{
  "expo": {
    "name": "Noted!",
    "slug": "noted",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Noted!",
      "shortName": "Noted!",
      "description": "A minimal bullet journal for capturing thoughts, tasks, events and ideas.",
      "themeColor": "#E8EDF2",
      "backgroundColor": "#E8EDF2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uk.lfranca.noted"
    },
    "android": {
      "package": "uk.lfranca.noted"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ]
  }
}
